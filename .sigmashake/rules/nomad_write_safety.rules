# nomad_write_safety.rules
# Technology: nomad | Capability: write

rule nomad-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_nomad_PATTERN"
  MESSAGE "Blocked an unsafe pattern in nomad. Use the recommended best practices for 2025/2026."
}

rule nomad-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_nomad_API"
  MESSAGE "You are using an outdated API for nomad. Please upgrade to the newer API."
}
